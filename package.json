{
    "name": "game_engine",
    "version": "2.0.0",
    "type": "module",
    "packageManager": "pnpm@10.33.0",
    "devDependencies": {
        "prettier": "^3.8.3",
        "qunit": "^2.25.0",
        "rimraf": "^6.1.3",
        "typedoc": "^0.28.19",
        "typedoc-plugin-markdown": "^4.11.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.9"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && vite build --mode production && pnpm run build:types",
        "build:types": "tsc --emitDeclarationOnly --declaration --declarationDir release/$npm_package_version",
        "preview": "vite preview",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "docs": "pnpm run docs:clean && pnpm run docs:build",
        "docs:clean": "rimraf docs/",
        "docs:build": "typedoc --plugin typedoc-plugin-markdown --out docs/ source/index.ts --name \"Game Engine\" --readme none --formatWithPrettier"
    },
    "dependencies": {
        "@drk4/utilities": "^6.3.2"
    }
}
