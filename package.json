{
    "name": "@drk4/game-engine",
    "displayName": "game-engine",
    "version": "2.0.0",
    "description": "A 2D game engine for simple browser games using the HTML canvas.",
    "author": {
        "name": "Pedro Ferreira",
        "email": "plferreira4@gmail.com",
        "url": "https://pedruu.ch/"
    },
    "license": "MIT",
    "type": "module",
    "main": "./dist/game_engine.js",
    "module": "./dist/game_engine.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/game_engine.js"
        },
        "./style.css": "./dist/game_engine.css"
    },
    "files": [
        "dist/",
        "license.txt",
        "readme.md"
    ],
    "sideEffects": [
        "./dist/game_engine.css"
    ],
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/noobiept/game_engine"
    },
    "keywords": [
        "game-engine",
        "canvas",
        "2d",
        "browser-game",
        "typescript"
    ],
    "packageManager": "pnpm@10.33.0",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@vitest/coverage-v8": "4.1.5",
        "eslint": "^10.2.1",
        "globals": "^17.5.0",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "typedoc": "^0.28.19",
        "typedoc-plugin-markdown": "^4.11.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0",
        "vite": "^8.0.10",
        "vitest": "^4.1.5"
    },
    "scripts": {
        "dev": "vite",
        "build": "pnpm run typecheck && pnpm run build:clean && vite build --mode production && pnpm run build:types && pnpm run build:css",
        "build:clean": "rimraf dist/",
        "build:css": "node -e \"import('node:fs').then(fs => fs.copyFileSync('source/css/game_engine.css', 'dist/game_engine.css'))\"",
        "tsc:w": "pnpm exec tsc --noEmit --watch -p tsconfig.json",
        "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json",
        "typecheck:examples": "pnpm exec tsc --noEmit -p examples/tsconfig.json",
        "typecheck:all": "pnpm run typecheck && pnpm run typecheck:examples",
        "build:types": "tsc --emitDeclarationOnly --declaration --declarationDir dist",
        "preview": "vite preview",
        "test": "vitest run --coverage",
        "test:unit": "vitest run",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "docs": "pnpm run docs:clean && pnpm run docs:build",
        "docs:clean": "rimraf docs/",
        "docs:build": "typedoc --plugin typedoc-plugin-markdown --out docs/ source/index.ts --name \"Game Engine\" --readme none --formatWithPrettier"
    },
    "dependencies": {
        "@drk4/utilities": "^6.3.2"
    }
}
